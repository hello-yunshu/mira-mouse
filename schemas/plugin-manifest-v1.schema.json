{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mira:schema:plugin-manifest:v1",
  "title": "Mira Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginId", "name", "version", "pluginApi", "evidence", "permissions", "capabilities", "writesEnabled"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "pluginId": { "type": "string", "pattern": "^[a-z0-9-]+(?:\\.[a-z0-9-]+)+$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$" },
    "pluginApi": { "type": "string", "minLength": 1 },
    "publisherKeyId": { "type": ["string", "null"] },
    "evidence": { "enum": ["source-confirmed", "fixture-verified", "build-verified", "hardware-verified", "inferred", "unknown", "blocked"] },
    "permissions": { "type": "array", "maxItems": 32, "items": { "type": "object" } },
    "capabilities": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "control", "labelKey"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "control": { "enum": ["Toggle", "Segmented", "Select", "Slider", "Number", "Color", "GradientStops", "DpiStages", "LightingZone", "ReadOnlyValue", "Action", "Info"] },
          "labelKey": { "type": "string", "minLength": 1 },
          "readOnly": { "type": "boolean", "default": false },
          "placements": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["region"],
              "properties": {
                "region": { "enum": ["hero", "control", "status", "details"] },
                "group": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "order": { "type": "integer", "minimum": -1000, "maximum": 1000, "default": 0 },
                "span": { "type": "integer", "minimum": 1, "maximum": 3, "default": 1 },
                "icon": { "enum": ["battery", "gauge", "wave", "lightbulb", "timer", "profile", "info", "settings"] }
              }
            }
          },
          "metadata": {
            "type": "object",
            "properties": {
              "mutation": { "$ref": "#/$defs/mutationDecl" },
              "mutations": {
                "type": "object",
                "additionalProperties": { "$ref": "#/$defs/mutationDecl" },
                "propertyNames": { "pattern": "^[a-z][a-zA-Z0-9-]*$" }
              },
              "bindings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["when", "source", "mutation"],
                  "properties": {
                    "when": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["path", "eq"],
                      "properties": {
                        "path": { "type": "string", "minLength": 1 },
                        "eq": {}
                      }
                    },
                    "source": { "type": "string", "minLength": 1 },
                    "mutation": { "$ref": "#/$defs/mutationDecl" },
                    "param": { "type": "string", "minLength": 1 },
                    "label": { "type": "string", "minLength": 1 }
                  }
                }
              },
              "param": { "type": "string", "minLength": 1 },
              "unit": { "type": "string", "maxLength": 16 },
              "format": { "enum": ["sleep", "color"] },
              "range": { "$ref": "#/$defs/rangeSpec" },
              "source": { "type": "string", "minLength": 1 },
              "actionLabel": { "type": "string", "minLength": 1 },
              "params": { "type": "object" },
              "section": { "enum": ["hero", "control", "status", "details"] },
              "status": { "type": "boolean" },
              "label": { "type": "string", "minLength": 1 },
              "options": {
                "type": "array",
                "maxItems": 8,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["value", "label"],
                  "properties": {
                    "value": { "type": ["string", "number", "boolean"] },
                    "label": { "type": "string", "minLength": 1, "maxLength": 48 }
                  }
                }
              },
              "summary": {
                "type": "array",
                "maxItems": 4,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["label", "source"],
                  "properties": {
                    "label": { "type": "string", "minLength": 1, "maxLength": 48 },
                    "source": { "type": "string", "minLength": 1, "maxLength": 160 },
                    "unit": { "type": "string", "maxLength": 16 },
                    "format": { "enum": ["sleep", "color"] },
                    "options": {
                      "type": "array",
                      "maxItems": 32,
                      "items": {
                        "type": "object",
                        "additionalProperties": false,
                        "required": ["value", "label"],
                        "properties": {
                          "value": { "type": ["string", "number", "boolean"] },
                          "label": { "type": "string", "minLength": 1, "maxLength": 48 }
                        }
                      }
                    }
                  }
                }
              },
              "effectOptions": {
                "type": "object",
                "additionalProperties": false,
                "required": ["effect"],
                "properties": {
                  "offValue": { "type": "number" },
                  "effect": {
                    "type": "array",
                    "maxItems": 32,
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value", "labelKey"],
                      "properties": {
                        "value": { "type": "number" },
                        "labelKey": { "type": "string", "minLength": 1 },
                        "requiresExtraColor": { "type": "boolean", "default": false }
                      }
                    }
                  },
                  "speed": { "$ref": "#/$defs/rangeSpec" },
                  "brightness": { "$ref": "#/$defs/rangeSpec" }
                }
              },
              "receiverLightingOptions": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "effect": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value", "labelKey"],
                      "properties": {
                        "value": { "type": "number" },
                        "labelKey": { "type": "string", "minLength": 1 }
                      }
                    }
                  },
                  "speed": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value", "labelKey"],
                      "properties": {
                        "value": { "type": "number" },
                        "labelKey": { "type": "string", "minLength": 1 }
                      }
                    }
                  },
                  "brightness": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value", "labelKey"],
                      "properties": {
                        "value": { "type": "number" },
                        "labelKey": { "type": "string", "minLength": 1 }
                      }
                    }
                  },
                  "option": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["value", "labelKey"],
                      "properties": {
                        "value": { "type": "number" },
                        "labelKey": { "type": "string", "minLength": 1 }
                      }
                    }
                  }
                }
              },
              "lightingRole": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "mouse": { "$ref": "#/$defs/mutationDecl" },
                  "receiver": { "$ref": "#/$defs/mutationDecl" }
                }
              }
            }
          },
          "probe": {
            "type": "object",
            "additionalProperties": false,
            "required": ["output", "field"],
            "properties": {
              "output": { "type": "string", "minLength": 1 },
              "field": { "type": "string", "minLength": 1 }
            }
          },
          "connections": {
            "type": "array",
            "items": { "enum": ["usb", "receiver", "bluetooth"] }
          },
          "minFirmware": { "type": "string" }
        }
      }
    },
    "writesEnabled": { "type": "boolean" },
    "exportableFields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "exportKey"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "exportKey": { "type": "string", "minLength": 1 },
          "kind": { "type": "string" },
          "mutation": { "type": "string" },
          "param": { "type": "string" },
          "source": { "type": "string" },
          "sources": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pluginId"],
        "properties": {
          "pluginId": { "type": "string", "minLength": 1 },
          "version": { "type": "string" },
          "reuseTransport": { "type": "boolean", "default": false }
        }
      }
    }
  },
  "$defs": {
    "mutationDecl": {
      "description": "Mutation declaration: a single mutation name or a priority-ordered candidate array. Host picks the first candidate supported by device.writableMutations.",
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9-]*$" },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9-]*$" }
        }
      ]
    },
    "rangeSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 }
      }
    }
  }
}
