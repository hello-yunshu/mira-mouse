{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:mira:schema:plugin-manifest:v1",
  "title": "Mira Plugin Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "pluginId", "name", "version", "pluginApi", "evidence", "permissions", "capabilities", "writesEnabled"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "pluginId": { "type": "string", "pattern": "^[a-z0-9-]+(?:\\.[a-z0-9-]+)+$" },
    "name": { "type": "string", "minLength": 1, "maxLength": 120 },
    "version": { "type": "string", "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:[-+][0-9A-Za-z.-]+)?$" },
    "pluginApi": { "type": "string", "minLength": 1 },
    "publisherKeyId": { "type": ["string", "null"] },
    "evidence": { "enum": ["source-confirmed", "fixture-verified", "build-verified", "hardware-verified", "inferred", "unknown", "blocked"] },
    "permissions": { "type": "array", "maxItems": 32, "items": { "type": "object" } },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "wakeRecovery": {
          "type": "object",
          "additionalProperties": false,
          "required": ["activitySource", "componentId", "connections"],
          "properties": {
            "activitySource": { "const": "system-pointer" },
            "componentId": { "type": "string", "minLength": 1, "maxLength": 32, "pattern": "^[a-z][a-z0-9-]*$" },
            "connections": {
              "type": "array",
              "minItems": 1,
              "maxItems": 4,
              "uniqueItems": true,
              "items": { "enum": ["usb", "wireless", "bluetooth", "virtual"] }
            }
          }
        },
        "inventory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["workflows"],
          "properties": {
            "workflows": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "refresh": { "type": "string", "enum": ["on-open", "manual"] },
            "cacheTtlSeconds": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "control", "labelKey"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "control": { "enum": ["Toggle", "Segmented", "Select", "Slider", "Number", "Color", "GradientStops", "DpiStages", "LightingZone", "ReadOnlyValue", "Action"] },
          "labelKey": { "type": "string", "minLength": 1 },
          "readOnly": { "type": "boolean", "default": false },
          "placements": {
            "type": "array",
            "maxItems": 8,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["region"],
              "properties": {
                "region": { "enum": ["hero", "control", "status", "details"] },
                "group": { "type": "string", "pattern": "^[a-z0-9-]+$" },
                "order": { "type": "integer", "minimum": -1000, "maximum": 1000, "default": 0 },
                "span": { "type": "integer", "minimum": 1, "maximum": 3, "default": 1 },
                "icon": { "enum": ["battery", "gauge", "wave", "lightbulb", "timer", "profile", "info", "settings"] }
              }
            }
          },
          "metadata": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "accentSource": { "type": "string", "minLength": 1, "maxLength": 160 },
              "fields": {
                "type": "array",
                "maxItems": 32,
                "items": { "$ref": "#/$defs/field" }
              },
              "zones": {
                "type": "array",
                "maxItems": 8,
                "items": { "$ref": "#/$defs/zone" }
              },
              "stageLayout": { "$ref": "#/$defs/stageLayout" },
              "statusDisplay": { "$ref": "#/$defs/statusDisplay" },
              "summary": {
                "type": "array",
                "maxItems": 4,
                "items": { "$ref": "#/$defs/summaryItem" }
              },
              "stateMapping": {
                "type": "object",
                "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 160 },
                "propertyNames": { "pattern": "^[a-zA-Z][a-zA-Z0-9-]*$" }
              },
              "batteryHistory": {
                "type": "object",
                "additionalProperties": false,
                "required": ["validConnections"],
                "properties": {
                  "validConnections": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 4,
                    "uniqueItems": true,
                    "items": { "enum": ["usb", "wireless", "bluetooth", "virtual"] }
                  }
                }
              },
              "visibleWhen": { "$ref": "#/$defs/visibleWhen" }
            }
          },
          "probe": {
            "type": "object",
            "additionalProperties": false,
            "required": ["output", "field"],
            "properties": {
              "output": { "type": "string", "minLength": 1 },
              "field": { "type": "string", "minLength": 1 }
            }
          },
          "connections": {
            "type": "array",
            "items": { "enum": ["usb", "receiver", "bluetooth"] }
          },
          "minFirmware": { "type": "string" }
        }
      }
    },
    "writesEnabled": { "type": "boolean" },
    "exportableFields": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "exportKey"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "exportKey": { "type": "string", "minLength": 1 },
          "kind": { "type": "string" },
          "mutation": { "type": "string" },
          "param": { "type": "string" },
          "source": { "type": "string" },
          "sources": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pluginId"],
        "properties": {
          "pluginId": { "type": "string", "minLength": 1 },
          "version": { "type": "string" },
          "reuseTransport": { "type": "boolean", "default": false }
        }
      }
    }
  },
  "$defs": {
    "mutationDecl": {
      "description": "Mutation declaration: a single mutation name or a priority-ordered candidate array. Host picks the first candidate supported by device.writableMutations.",
      "oneOf": [
        { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9-]*$" },
        {
          "type": "array",
          "minItems": 1,
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9-]*$" }
        }
      ]
    },
    "rangeSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max"],
      "properties": {
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "editor"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64, "pattern": "^[a-z][a-z0-9-]*$" },
        "source": { "type": "string", "minLength": 1, "maxLength": 160 },
        "mutation": { "$ref": "#/$defs/mutationDecl" },
        "param": { "type": "string", "minLength": 1, "maxLength": 32 },
        "params": { "type": "object" },
        "paramSources": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": { "type": "string", "minLength": 1, "maxLength": 32 },
          "additionalProperties": { "type": "string", "minLength": 1, "maxLength": 160 }
        },
        "editor": { "enum": ["inline-toggle", "inline-segmented", "inline-value", "inline-action", "modal-select", "modal-color", "modal-range", "modal-number", "modal-dpi-stage", "modal-gradient", "static-readonly"] },
        "labelKey": { "type": "string", "minLength": 1 },
        "labelSource": { "type": "string", "minLength": 1, "maxLength": 160 },
        "editTitleKey": { "type": "string", "minLength": 1, "maxLength": 160 },
        "editLabelKey": { "type": "string", "minLength": 1, "maxLength": 160 },
        "options": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "labelKey"],
            "properties": {
              "value": { "type": ["string", "number", "boolean"] },
              "labelKey": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        },
        "optionSource": { "type": "string", "minLength": 1, "maxLength": 160 },
        "range": { "$ref": "#/$defs/rangeSpec" },
        "format": { "enum": ["sleep", "percent", "hertz", "connection", "color", "default"] },
        "visibleWhen": { "$ref": "#/$defs/visibleWhen" },
        "switch": { "$ref": "#/$defs/switchDecl" }
      }
    },
    "zone": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "labelKey", "fields"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 32, "pattern": "^[a-z][a-z0-9-]*$" },
        "labelKey": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/field" }
        },
        "visibleWhen": { "$ref": "#/$defs/visibleWhen" }
      }
    },
    "stageLayout": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dotsSource", "selectMutation", "setMutation", "valueSource", "range"],
      "properties": {
        "dotsSource": { "type": "string", "minLength": 1, "maxLength": 160 },
        "selectMutation": { "$ref": "#/$defs/mutationDecl" },
        "setMutation": { "$ref": "#/$defs/mutationDecl" },
        "valueSource": { "type": "string", "minLength": 1, "maxLength": 160 },
        "colorSource": { "type": "string", "minLength": 1, "maxLength": 160 },
        "range": { "$ref": "#/$defs/rangeSpec" },
        "selectParam": { "type": "string", "minLength": 1, "maxLength": 32 },
        "stageParam": { "type": "string", "minLength": 1, "maxLength": 32 },
        "valueParam": { "type": "string", "minLength": 1, "maxLength": 32 }
      }
    },
    "statusDisplay": {
      "type": "object",
      "additionalProperties": false,
      "required": ["valueSource"],
      "properties": {
        "labelKey": { "type": "string", "minLength": 1, "maxLength": 160 },
        "valueSource": { "type": "string", "minLength": 1, "maxLength": 160 },
        "valueFormat": { "enum": ["sleep", "percent", "hertz", "connection", "color", "default"] },
        "valueOptions": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "labelKey"],
            "properties": {
              "value": { "type": ["string", "number", "boolean"] },
              "labelKey": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        },
        "onClickField": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    },
    "summaryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "anyOf": [
        { "required": ["labelKey"] },
        { "required": ["label"] }
      ],
      "properties": {
        "labelKey": { "type": "string", "minLength": 1, "maxLength": 160 },
        "label": { "type": "string", "minLength": 1, "maxLength": 24 },
        "source": { "type": "string", "minLength": 1, "maxLength": 160 },
        "unit": { "type": "string", "maxLength": 12 },
        "format": { "enum": ["sleep", "percent", "hertz", "connection", "color", "default"] },
        "options": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "labelKey"],
            "properties": {
              "value": { "type": ["string", "number", "boolean"] },
              "labelKey": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        }
      }
    },
    "visibleWhen": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 160 },
        "eq": {},
        "ne": {}
      }
    },
    "switchDecl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "offValue"],
      "properties": {
        "source": { "type": "string", "minLength": 1, "maxLength": 160 },
        "offValue": { "type": ["string", "number", "boolean", "null"] },
        "restoreField": { "type": "string", "minLength": 1, "maxLength": 64 }
      }
    }
  }
}
