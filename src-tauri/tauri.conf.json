{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mira",
  "identifier": "run.hey.mira",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build && node scripts/check-local-ai-assets.mjs",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Mira",
        "width": 460,
        "height": 660,
        "minWidth": 400,
        "minHeight": 560,
        "maximizable": false,
        "transparent": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis",
      "appimage",
      "deb",
      "rpm"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/plugins/mira-amaster-1.6.3.mira-plugin",
      "resources/plugins/mira-logitech-hidpp-0.8.1.mira-plugin",
      "resources/local-ai/model.rillpack"
    ],
    "externalBin": [
      "binaries/mira-runtime"
    ],
    "fileAssociations": [
      {
        "ext": [
          "mira-plugin"
        ],
        "name": "Mira Plugin",
        "description": "Declarative Mira device plugin",
        "role": "Editor"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": "-",
      "dmg": {
        "background": "../scripts/assets/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 160,
          "y": 200
        },
        "applicationFolderPosition": {
          "x": 500,
          "y": 200
        }
      }
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "headerImage": "../scripts/assets/windows-nsis-header.bmp",
        "sidebarImage": "../scripts/assets/windows-nsis-sidebar.bmp",
        "uninstallerHeaderImage": "../scripts/assets/windows-nsis-uninstall-header.bmp",
        "installMode": "currentUser",
        "languages": [
          "SimpChinese",
          "English"
        ],
        "startMenuFolder": "Mira"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://gh-proxy.com/https://github.com/hello-yunshu/mira-mouse/releases/latest/download/latest.json",
        "https://github.com/hello-yunshu/mira-mouse/releases/latest/download/latest.json",
        "https://github.hey.run/hello-yunshu/mira-mouse/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "quiet"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJGMTVEOEZDRUI0MTVBMkMKUldRc1drSHIvTmdWdnpsaThmK3F6d0s2QXBhVWJvRUFvRnBEd0RJUXlDWHBhRmROdUdERm5GaEgK"
    }
  }
}
