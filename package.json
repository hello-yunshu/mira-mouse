{
  "name": "@mira/app",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "assets:windows-installer": "python3 scripts/generate-windows-installer-assets.py",
    "build:dmg": "npm exec tauri build -- --bundles dmg",
    "version:print": "node scripts/app-version.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "lint": "eslint .",
    "prepare": "simple-git-hooks || true",
    "check:quick": "bash scripts/quick-check.sh",
    "check:ci": "bash scripts/local-ci.sh",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "check:structured": "node scripts/check-structured.mjs && node scripts/check-version-sources.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@tauri-apps/api": "^2.5.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.5.0",
    "i18next": "^26.3.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-i18next": "^17.0.8"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "simple-git-hooks": "^2.13.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "simple-git-hooks": {
    "pre-push": "[ \"${MIRA_SKIP_HOOKS:-}\" = 1 ] && exit 0 || npm run check:quick"
  }
}
